    {
      "parameters": {
        "description": "Use this tool automatically when the user uploads a file. You MUST pass the string 'code' into the file_type parameter. Do NOT output raw JSON to the user.",
        "jsCode": "// Check if a binary file was actually uploaded in the chat input\nif (!_input.item?.binary) {\n    return { error: \"No file was uploaded. Please attach a file to your chat message.\" };\n}\n\ntry {\n    // Locate the first attached file in the n8n incoming data stream\n    const binaryKeys = Object.keys(_input.item.binary);\n    const primaryFileKey = binaryKeys[0];\n    const fileData = _input.item.binary[primaryFileKey];\n\n    // Read the file's raw base64 data stream and decode it into standard UTF-8 string text\n    const decodedCodeContent = Buffer.from(fileData.data, 'base64').toString('utf-8');\n\n    return {\n        filename: fileData.fileName || \"uploaded_code.py\",\n        content: decodedCodeContent\n    };\n} catch (error) {\n    return { error: `Failed to process uploaded file: ${error.message}` };\n}",
        "specifyInputSchema": true,
        "jsonSchemaExample": "{\n  \"file_type\": \"python\"\n}"
      },
